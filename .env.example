# ===========================================
# AI Test Forge - 환경변수 설정
# ===========================================
# 이 파일을 .env로 복사한 후 값을 채워주세요.
# cp .env.example .env

# --- 프로필 ---
APP_PROFILE=local

# --- 데이터베이스 ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_test_forge
DB_USERNAME=root
DB_PASSWORD=
MYSQL_ROOT_PASSWORD=

# --- AI 설정 ---
# 프로바이더별 API Key (공유)
OPENAI_API_KEY=
CLAUDE_API_KEY=
OPENROUTER_API_KEY=

# Reasoning 모델 (고성능 — Agent Loop 메인 대화)
# 서버 설정에서만 변경 가능 (런타임 변경 불가)
AI_REASONING_PROVIDER=openai
AI_REASONING_MODEL=gpt-4o
AI_REASONING_MAX_INPUT=120000
AI_REASONING_MAX_OUTPUT=16000

# Fast 모델 (경량 — 2-Stage 필터, Body 생성, 힌트)
# 서버 설정에서만 변경 가능 (런타임 변경 불가)
AI_FAST_PROVIDER=openai
AI_FAST_MODEL=gpt-4o-mini
AI_FAST_MAX_INPUT=120000
AI_FAST_MAX_OUTPUT=4000

# --- 서버 설정 ---
SERVER_PORT=8080

# --- JWT ---
# Base64 인코딩된 시크릿 키 (최소 32바이트)
# 생성: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# --- CORS ---
# 개발 시: Vite dev server(5173)에서 API 호출하므로 필요
# 프로덕션: FE+BE 통합 빌드(같은 origin)이면 자기 자신을 명시
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Agent Loop 설정 ---
AGENT_MAX_ITERATIONS=20
AGENT_MAX_TOOL_CALLS_PER_TURN=5
AGENT_TIMEOUT_SECONDS=120
AGENT_MAX_CONCURRENT=10
AGENT_TWO_STAGE_THRESHOLD=30

# --- AI Retry 설정 ---
AI_RETRY_MAX_ATTEMPTS=3
AI_RETRY_INITIAL_DELAY_MS=1000
AI_RETRY_MULTIPLIER=2.0

# --- Spec Registry ---
# SPEC_STALE_THRESHOLD=5m
# SPEC_AUTO_DELETE_THRESHOLD=30m
# SPEC_ASYNC_THRESHOLD=5242880
