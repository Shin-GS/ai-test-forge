# ===========================================
# AI Test Forge - 환경변수 설정
# ===========================================
# 이 파일을 .env로 복사한 후 값을 채워주세요.
# cp .env.example .env

# --- 프로필 ---
APP_PROFILE=local

# --- 데이터베이스 ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_test_forge
DB_USERNAME=root
DB_PASSWORD=

# --- AI 설정 ---
# 사용할 AI 프로바이더: openai | claude | mock
AI_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- 서버 설정 ---
SERVER_PORT=8080

# --- JWT ---
# Base64 인코딩된 시크릿 키 (최소 32바이트)
# 생성: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Agent Loop 설정 ---
AGENT_MAX_ITERATIONS=20
AGENT_MAX_TOOL_CALLS_PER_TURN=5
AGENT_TIMEOUT_SECONDS=120
